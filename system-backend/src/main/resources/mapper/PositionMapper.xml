<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.xumob.restaurant.mapper.PositionMapper">

    <resultMap id="positionResultMap" type="Position">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="code" property="code"/>
        <result column="level" property="level"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, code, level, description, create_time, update_time
    </sql>

    <select id="selectById" resultMap="positionResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM position
        WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="positionResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM position
        WHERE code = #{code}
    </select>

</mapper>
