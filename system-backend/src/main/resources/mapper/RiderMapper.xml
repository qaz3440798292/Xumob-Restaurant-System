<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.xumob.restaurant.mapper.RiderMapper">

    <resultMap id="riderResultMap" type="Rider">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="name" property="name"/>
        <result column="phone" property="phone"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, username, password, name, phone, status, create_time, update_time
    </sql>

    <select id="selectByRiderId" resultMap="riderResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM rider
        WHERE id = #{id}
    </select>

    <select id="selectByUsername" resultMap="riderResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM rider
        WHERE username = #{username}
    </select>

    <insert id="createRider" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO rider (username, password, name, phone, status, create_time, update_time)
        VALUES (#{username}, #{password}, #{name}, #{phone}, #{status}, #{createTime}, #{updateTime})
    </insert>

    <select id="selectAllRiders" resultMap="riderResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM rider
    </select>

</mapper>
